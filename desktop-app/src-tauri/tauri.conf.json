{
  "productName": "Zyntra",
  "version": "2.2.0",
  "identifier": "com.zyntra.erp",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Zyntra - Sistema de Gestão Empresarial",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src * 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'self' 'unsafe-inline' 'unsafe-eval'; style-src * 'self' 'unsafe-inline'; font-src * 'self' data:; img-src * 'self' data: blob:; connect-src * 'self' ws: wss: data:; frame-src * 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "copyright": "© 2026 Zyntra — Aluforce Indústria e Comércio",
    "category": "Business",
    "shortDescription": "Zyntra - Sistema de Gestão Empresarial",
    "longDescription": "Zyntra - Plataforma completa de gestão empresarial com módulos de Vendas, Financeiro, PCP, Logística, RH, Compras, Faturamento NF-e e muito mais.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["PortugueseBR", "English"],
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "RWTwwaaPoHmUtbU6S+tXlPMsjs4U2BGg8C498SongJIbdp5cTOhosOOj",
      "endpoints": [
        "https://github.com/aluforce/zyntra-desktop/releases/latest/download/latest.json"
      ]
    },
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["zyntra"]
      }
    }
  }
}
