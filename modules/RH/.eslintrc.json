{
  "env": {
    "node": true,
    "es2021": true
  },
  "rules": {
    "no-console": "off",
    "prefer-const": "off"
  },
  "overrides": [
    {
      "files": ["public/**/*.js"],
      "env": { "browser": true, "node": false },
      "globals": {
        "localStorage": "readonly",
        "showToast": "readonly",
        "openModal": "readonly",
        "closeModal": "readonly",
        "fetch": "readonly",
        "FormData": "readonly"
      },
      "rules": {
        "no-undef": "off"
      }
    }
  ]
}
