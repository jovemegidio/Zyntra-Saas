# ─────────────────────────────────────────────────────────────────────────────
# GloryBank — Environment Variables
#
# Template voltado para deploy online em modo apresentação.
# Use apenas valores públicos/deploy, sem referências locais.
# ─────────────────────────────────────────────────────────────────────────────

# ── DEMO MODE ────────────────────────────────────────────────────────────────
# Set to "true" para publicar a apresentação sem banco ou Asaas.
# Login: demo@glorybank.com / Demo@123456
# All API responses are mocked — no real money is moved.
DEMO_MODE=true

# ── JWT Secret ───────────────────────────────────────────────────────────────
# Generate: use qualquer gerador seguro de segredo com 64+ caracteres.
JWT_SECRET="change-this-to-a-64-char-random-secret-before-going-to-production"

# ── App URL ──────────────────────────────────────────────────────────────────
# Use sempre a URL pública do deploy/apresentação
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Database (optional, fora do escopo da apresentação) ──────────────────────
# Supports: Neon, Railway, Supabase, Prisma Postgres, or any PostgreSQL provider
# DATABASE_URL="postgresql://user:password@db.example.com:5432/glorybank?schema=public"

# ── Asaas API (optional, fora do escopo da apresentação) ─────────────────────
# Sandbox key at: https://sandbox.asaas.com → Configurações → Integrações
# ASAAS_API_KEY="$aact_your_sandbox_key_here"
# ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
# Production:   https://api.asaas.com/api/v3
