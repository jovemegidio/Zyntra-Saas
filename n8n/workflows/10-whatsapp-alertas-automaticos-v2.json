      "name": "📊 Resumo Diário (tarde)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [480, 900],
      "typeVersion": 4.1,
      "id": "http-resumo-10"
    },
    {
      "parameters": {
        "functionCode": "// Coletar resultados da rodada da tarde\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n  results.push({\n    modulo: data?.message || 'desconhecido',\n    total: data?.total || 0,\n    success: data?.success || false\n  });\n}\n\nreturn [{\n  json: {\n    resultados: results,\n    horario: new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' }),\n    tipo: 'tarde'\n  }\n}];"
      },
      "name": "⚙️ Consolidar Resultados Tarde",
      "type": "n8n-nodes-base.code",
      "position": [740, 800],
      "typeVersion": 2,
      "id": "code-consolidar-tarde-10"
    },
