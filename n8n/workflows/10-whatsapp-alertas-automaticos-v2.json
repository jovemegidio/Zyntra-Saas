    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.ALUFORCE_API_URL}}/api/whatsapp-alertas/nfe-pendentes",
        "options": { "timeout": 30000 }
      },
      "name": "📄 NFe Pendentes",
      "type": "n8n-nodes-base.httpRequest",
      "position": [480, 850],
      "typeVersion": 4.1,
      "id": "http-nfe-10"
    },
    {
      "parameters": {
        "functionCode": "// Coletar resultados de todos os módulos\nconst items = $input.all();\nconst results = [];\nlet totalAlertas = 0;\n\nfor (const item of items) {\n  const data = item.json;\n  const modulo = data?.message || data?.error || 'desconhecido';\n  const total = data?.total || 0;\n  const success = data?.success || false;\n  \n  results.push({\n    modulo: modulo,\n    total: total,\n    success: success\n  });\n  \n  if (success && total > 0) totalAlertas += total;\n}\n\nreturn [{\n  json: {\n    total_alertas: totalAlertas,\n    resultados: results,\n    horario: new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' }),\n    tipo: 'manha'\n  }\n}];"
      },
      "name": "⚙️ Consolidar Resultados Manhã",
      "type": "n8n-nodes-base.code",
      "position": [740, 400],
      "typeVersion": 2,
      "id": "code-consolidar-manha-10"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.ALUFORCE_API_URL}}/api/whatsapp-alertas/contas-pagar",
        "options": { "timeout": 30000 }
