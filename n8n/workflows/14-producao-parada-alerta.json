              "mensagem": "⚠️ *{{$json.total}}* ordens de produção sem movimentação há +24h.\n\nVerifique no Zyntra → PCP"
            }
          },
          "options": {}
        },
        "name": "📱 WhatsApp PCP",
        "type": "n8n-nodes-base.httpRequest",
        "position": [910, 400],
        "typeVersion": 4.1
      },
      {
        "parameters": {
          "method": "POST",
          "url": "={{$env.ALUFORCE_API_URL}}/api/n8n/eventos/workflow-concluido",
          "headerParameters": {
            "parameters": [{ "name": "X-N8N-API-Key", "value": "={{$env.ALUFORCE_API_KEY}}" }]
          },
          "body": { "workflow_id": "14", "workflow_name": "Produção Parada Alerta", "status": "success" },
          "options": {}
        },
        "name": "✅ Notificar",
        "type": "n8n-nodes-base.httpRequest",
        "position": [1130, 300],
        "typeVersion": 4.1
      }
    ],
    "connections": {
      "⏰ 10h e 16h Seg-Sex": { "main": [[{ "node": "🏭 Buscar OPs Paradas", "type": "main", "index": 0 }]] },
      "🏭 Buscar OPs Paradas": { "main": [[{ "node": "Tem OPs paradas?", "type": "main", "index": 0 }]] },
      "Tem OPs paradas?": { "main": [[{ "node": "📧 Alerta PCP", "type": "main", "index": 0 }, { "node": "📱 WhatsApp PCP", "type": "main", "index": 0 }], [{ "node": "✅ Notificar", "type": "main", "index": 0 }]] },
      "📧 Alerta PCP": { "main": [[{ "node": "✅ Notificar", "type": "main", "index": 0 }]] }
    },
    "settings": { "timezone": "America/Sao_Paulo" }
  }
