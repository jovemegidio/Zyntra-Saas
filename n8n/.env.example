# =====================================================
# n8n — Variáveis de Ambiente para Integração
# Adicionar ao seu .env principal
# =====================================================

# ── n8n Ativação ──────────────────────────────────────
N8N_ENABLED=true
N8N_HOST=n8n.aluforce.api.br
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://n8n.aluforce.api.br/

# ── n8n Autenticação ─────────────────────────────────
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=SuaSenhaSegura2026!
N8N_ENCRYPTION_KEY=chave-encriptacao-unica-gerar-com-openssl

# ── n8n API Key (comunicação ALUFORCE ↔ n8n) ─────────
N8N_API_KEY=n8n-internal-key-gerar-uuid-unico-aqui

# ── n8n Database (usa MySQL compartilhado) ────────────
N8N_DB_NAME=n8n

# ── Discord Webhook (para notificações dos workflows) ─
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/SEU_WEBHOOK_ID/SEU_TOKEN

# ── Email para Relatórios ─────────────────────────────
EMAIL_RELATORIO_DIARIO=diretoria@aluforce.ind.br
